# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=                  # intake agent (tenant calls in via web)
ELEVENLABS_NEGOTIATOR_AGENT_ID=       # Theo Negotiates: simulated vendor agent
ELEVENLABS_WEBHOOK_SECRET=

# --- SendGrid (email DIY guides) ---
SENDGRID_API_KEY=

# --- AI ---
ANTHROPIC_API_KEY=

# --- Supabase (database + auth + realtime) ---
# Per Wynand's guidance: triage logs, transcripts, urgency classifications
# all written to Supabase for auditability and judging.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-side only, never expose

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Stripe (Theo Negotiates: TWO-SIDED MARKETPLACE) ---
# Flow 1: NeoTheo charges Handwerker a lead fee (% of winning bid)
#         off-session PaymentIntent on handwerker.stripe_customer_id
# Flow 2: Owner pays Handwerker via Connect destination charge
#         deposit on consent + final on completion
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_ACCOUNT_ID=
STRIPE_DEFAULT_DEPOSIT_PCT=30          # owner-side: % of bid held on deposit
STRIPE_DEFAULT_LEAD_FEE_PCT=10         # vendor-side: % of winning bid charged to Handwerker

# --- Theo Negotiates tuning ---
AUCTION_TIMEOUT_SECONDS=90
AUCTION_N_VENDORS=3
AUCTION_MAX_BUDGET_EUR=
