# --- ElevenLabs ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=                  # intake agent (tenant calls in)
ELEVENLABS_NEGOTIATOR_AGENT_ID=       # Theo Negotiates: outbound vendor agent
ELEVENLABS_WEBHOOK_SECRET=

# --- Twilio (phone routing + SMS + outbound auction dialer) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=

# --- SendGrid (email DIY guides) ---
SENDGRID_API_KEY=

# --- AI ---
ANTHROPIC_API_KEY=

# --- Database ---
DATABASE_URL=postgres://neotheo:neotheo@localhost:5432/neotheo

# --- Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:8000
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Stripe (Theo Negotiates: TWO-SIDED MARKETPLACE) ---
# Flow 1: NeoTheo charges Handwerker a lead fee (% of winning bid)
#         off-session PaymentIntent on handwerker.stripe_customer_id
# Flow 2: Owner pays Handwerker via Connect destination charge
#         deposit on consent + final on completion
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_ACCOUNT_ID=
STRIPE_DEFAULT_DEPOSIT_PCT=30          # owner-side: % of bid held on deposit
STRIPE_DEFAULT_LEAD_FEE_PCT=10         # vendor-side: % of winning bid charged to Handwerker

# --- Theo Negotiates tuning ---
AUCTION_TIMEOUT_SECONDS=90
AUCTION_N_VENDORS=3
AUCTION_MAX_BUDGET_EUR=
